{
  "title": "Home KM — System",
  "uid": "homekm-system",
  "schemaVersion": 39,
  "tags": ["homekm"],
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "JVM heap used",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "graph",
      "title": "HTTP req/s by status",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count[1m])) by (status)", "legendFormat": "{{status}}"}
      ]
    },
    {
      "type": "graph",
      "title": "HikariCP pool",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "hikaricp_connections_active", "legendFormat": "active"},
        {"expr": "hikaricp_connections_idle", "legendFormat": "idle"},
        {"expr": "hikaricp_connections_pending", "legendFormat": "pending"}
      ]
    },
    {
      "type": "graph",
      "title": "GC pause (95p, by collector)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(jvm_gc_pause_seconds_bucket[1m])) by (le, gc))", "legendFormat": "{{gc}}"}
      ]
    }
  ]
}

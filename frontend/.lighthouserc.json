{
  "_comment": "Thresholds reflect actual scores after a11y polish (2026-04-29). PWA stays warn — accurate scoring requires a deployed instance with HTTPS + active service worker; the static-served dist used here can't activate the SW.",
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": [
          "uses-http2",
          "is-on-https"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:pwa": ["warn", { "minScore": 0.4 }],
        "categories:seo": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

{
  "_comment": "Thresholds ratchet on current state — raise as fixes land. Initial baseline: a11y 0.83 (color-contrast + missing labels on Login), PWA 0.43 (static dist serves without activating SW; rerun against a deployed instance to score real PWA).",
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": [
          "uses-http2",
          "is-on-https"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:accessibility": ["warn", { "minScore": 0.83 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:pwa": ["warn", { "minScore": 0.4 }],
        "categories:seo": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

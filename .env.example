# Application
APP_NAME=Home KM
APP_THEME_COLOR=#6366f1

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=homekm
DB_USER=homekm
DB_PASSWORD=changeme
POSTGRES_PORT=5432
# HikariCP pool sizing — see specs/12-infrastructure.md
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=homekm
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Browser-visible MinIO origin used in the frontend CSP (img-src / media-src / connect-src).
# Leave empty if MinIO is not exposed to the browser; set to e.g. http://minio.lan:9000
# or https://files.example.com when presigned URLs are loaded from a third-party origin.
MINIO_PUBLIC_ORIGIN=

# JWT (base64-encoded secret, minimum 32 characters)
JWT_SECRET=change-this-to-a-long-random-base64-encoded-secret
JWT_EXPIRY_HOURS=24

# Security
BCRYPT_COST=12

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# File uploads
PRESIGNED_URL_EXPIRY_MINUTES=15
MAX_FILE_UPLOAD_MB=100

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Ports
API_PORT=8080
FRONTEND_PORT=3000

# Semantic search (optional). When enabled, search results can be ranked by
# cosine similarity over note/file/folder embeddings stored in pgvector.
# Bring up the bundled Ollama sidecar with `--profile semantic`, then run
# `docker exec -it homekm-ollama ollama pull nomic-embed-text` once.
# Switching models? Match EMBEDDING_DIM to the model's output dimension and
# add a Flyway migration that re-types the embedding columns to vector(N).
EMBEDDING_ENABLED=false
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Observability (optional). Set OTLP endpoint to forward traces to a collector
# (Tempo / Jaeger / Honeycomb / etc.). MGMT_TRACING_SAMPLING is the per-request
# sample rate (0.0 = off, 1.0 = every request). Sentry DSN is read by the
# frontend at build time via VITE_SENTRY_DSN; install @sentry/react in the
# frontend if you set it.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=homekm-api
MGMT_TRACING_SAMPLING=0.0
# Log a WARN to org.hibernate.SQL_SLOW for any DB query slower than this.
# Set to 0 to disable. Tune higher (e.g. 1000) on slow self-host hardware.
SQL_SLOW_THRESHOLD_MS=500
VITE_SENTRY_DSN=

# Application
APP_NAME=Home KM
APP_THEME_COLOR=#6366f1

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=homekm
DB_USER=homekm
DB_PASSWORD=changeme
POSTGRES_PORT=5432
# HikariCP pool sizing — see specs/12-infrastructure.md
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=homekm
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Browser-visible MinIO origin used in the frontend CSP (img-src / media-src / connect-src).
# Leave empty if MinIO is not exposed to the browser; set to e.g. http://minio.lan:9000
# or https://files.example.com when presigned URLs are loaded from a third-party origin.
MINIO_PUBLIC_ORIGIN=

# JWT (base64-encoded secret, minimum 32 characters)
JWT_SECRET=change-this-to-a-long-random-base64-encoded-secret
JWT_EXPIRY_HOURS=24

# Security
BCRYPT_COST=12

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# File uploads
PRESIGNED_URL_EXPIRY_MINUTES=15
MAX_FILE_UPLOAD_MB=100

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Ports
API_PORT=8080
FRONTEND_PORT=3000

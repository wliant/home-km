# Application
APP_NAME=Home KM
APP_THEME_COLOR=#6366f1

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=homekm
DB_USER=homekm
DB_PASSWORD=changeme
POSTGRES_PORT=5432

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=homekm
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# JWT (base64-encoded secret, minimum 32 characters)
JWT_SECRET=change-this-to-a-long-random-base64-encoded-secret
JWT_EXPIRY_HOURS=24

# Security
BCRYPT_COST=12

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# File uploads
PRESIGNED_URL_EXPIRY_MINUTES=15
MAX_FILE_UPLOAD_MB=100

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Ports
API_PORT=8080
FRONTEND_PORT=3000
